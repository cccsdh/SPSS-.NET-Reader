<Window x:Class="SpssViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPSS Viewer" Height="700" Width="1000">
    <DockPanel Margin="8">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button x:Name="OpenButton" Width="100" Click="OpenButton_Click">Open .sav</Button>
            <Button x:Name="ExportCsvButton" Width="120" Margin="8,0,0,0" Click="ExportCsvButton_Click">Export to CSV</Button>
            <Button x:Name="ExportXlsxButton" Width="140" Margin="8,0,0,0" Click="ExportXlsxButton_Click">Export to .xlsx</Button>
            <TextBlock x:Name="StatusText" Margin="12,4,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
            <ProgressBar x:Name="ProgressBar" Width="400" Height="16" Minimum="0" Maximum="100" Value="0" />
            <TextBlock x:Name="ProgressText" Margin="8,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
        <DataGrid x:Name="DataGrid" AutoGenerateColumns="True" CanUserAddRows="False" />
    </DockPanel>
</Window>